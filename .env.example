PORT=3000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/flower_bouquet_db

# JWT secrets MUST be >= 32 chars and NOT start with: replace_with_ / your_ / changeme
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret_at_least_32_chars
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret_at_least_32_chars
JWT_RESET_SECRET=replace_with_a_long_random_reset_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true
STABILITY_API_KEY=

# Shared secret for verifying payment-gateway webhook signatures
PAYMENT_WEBHOOK_SECRET=replace_with_a_long_random_webhook_secret_at_least_32_chars
